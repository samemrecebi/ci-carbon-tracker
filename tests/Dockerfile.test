FROM python:3.12-slim

RUN pip install --no-cache-dir numpy pandas pyyaml

COPY <<'EOF' /app/benchmark.py
import numpy as np
import time

print("Carbon tracker CI Docker build test")
print(f"NumPy version: {np.__version__}")
arr = np.random.rand(1000, 1000)
result = np.linalg.svd(arr, compute_uv=False)
print(f"SVD computed, top singular value: {result[0]:.4f}")
print("Sleeping 10 seconds...")
time.sleep(10)
print("Done")
EOF

RUN python /app/benchmark.py

WORKDIR /app
CMD ["python", "benchmark.py"]
